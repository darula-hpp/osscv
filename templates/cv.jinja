<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ cv.basics.name }}{% if github %} (@{{ github }}){% endif %} - Open Source CV</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
  <style>
    :root {
      --ink: #0c1222;
      --ink-soft: #3d4a63;
      --mute: #6b778f;
      --line: #e2e8f0;
      --paper: #f7f5f1;
      --card: #ffffff;
      --accent: #0f766e;
      --accent-hi: #14b8a6;
      --accent-deep: #115e59;
      --glow: rgba(20, 184, 166, 0.18);
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: "DM Sans", "Segoe UI", Helvetica, Arial, sans-serif;
      color: var(--ink);
      background:
        radial-gradient(1200px 500px at 10% -10%, var(--glow), transparent 55%),
        radial-gradient(900px 420px at 100% 0%, rgba(15, 118, 110, 0.08), transparent 50%),
        linear-gradient(180deg, #fbfaf7 0%, var(--paper) 100%);
      line-height: 1.5;
      font-size: 10.5pt;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    a { color: var(--accent-deep); text-decoration-thickness: 1px; text-underline-offset: 2px; }
    a:hover { color: var(--accent); }
    .sheet {
      max-width: 820px;
      margin: 28px auto;
      padding: 0 16px 40px;
    }
    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow:
        0 1px 0 rgba(255,255,255,0.8) inset,
        0 18px 40px rgba(12, 18, 34, 0.06);
      overflow: hidden;
    }
    .hero {
      display: grid;
      grid-template-columns: 112px 1fr;
      gap: 22px;
      align-items: center;
      padding: 28px 28px 22px;
      background:
        linear-gradient(135deg, rgba(20,184,166,0.10), transparent 42%),
        linear-gradient(180deg, #fff, #fafcfb);
      border-bottom: 1px solid var(--line);
    }
    @media (max-width: 560px) {
      .hero { grid-template-columns: 1fr; text-align: center; justify-items: center; }
    }
    .avatar {
      width: 112px;
      height: 112px;
      border-radius: 28px;
      object-fit: cover;
      border: 3px solid #fff;
      box-shadow: 0 8px 24px rgba(15, 118, 110, 0.22);
      background: #e2e8f0;
    }
    .avatar-fallback {
      display: grid;
      place-items: center;
      font-family: "Instrument Serif", Georgia, serif;
      font-size: 42px;
      color: var(--accent-deep);
      background: linear-gradient(145deg, #ccfbf1, #99f6e4);
    }
    .identity h1 {
      margin: 0;
      font-family: "Instrument Serif", Georgia, serif;
      font-size: 34px;
      font-weight: 400;
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--ink);
    }
    .label {
      margin-top: 6px;
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.01em;
    }
    .handle-row {
      margin-top: 10px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      justify-content: inherit;
    }
    .chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 10px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: #fff;
      font-size: 12px;
      font-weight: 600;
      color: var(--ink-soft);
      text-decoration: none;
    }
    .chip svg { flex-shrink: 0; opacity: 0.85; }
    .chip.live {
      border-color: rgba(20, 184, 166, 0.35);
      background: rgba(20, 184, 166, 0.08);
      color: var(--accent-deep);
    }
    .meta {
      margin-top: 8px;
      color: var(--mute);
      font-size: 12px;
    }
    .body { padding: 8px 28px 28px; }
    .summary {
      margin: 18px 0 6px;
      font-size: 14px;
      color: var(--ink-soft);
      max-width: 62ch;
    }
    section { margin-top: 22px; }
    h2 {
      margin: 0 0 12px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--accent-deep);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    h2::after {
      content: "";
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--line), transparent);
    }
    .skills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .skill {
      display: inline-flex;
      flex-direction: column;
      gap: 2px;
      min-width: 140px;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: linear-gradient(180deg, #fff, #f8fafc);
    }
    .skill strong {
      font-size: 12px;
      font-weight: 700;
      color: var(--ink);
    }
    .skill span {
      font-size: 11px;
      color: var(--mute);
      line-height: 1.35;
    }
    .item {
      margin-bottom: 14px;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: #fff;
    }
    .item-title {
      font-weight: 700;
      font-size: 13.5px;
      color: var(--ink);
    }
    .item-title a { color: inherit; text-decoration: none; }
    .item-title a:hover { color: var(--accent); text-decoration: underline; }
    .item-sub {
      margin-top: 2px;
      color: var(--mute);
      font-size: 11.5px;
      font-weight: 500;
    }
    .item p {
      margin: 6px 0 0;
      color: var(--ink-soft);
      font-size: 12.5px;
    }
    ul {
      margin: 8px 0 0;
      padding-left: 1.15em;
      color: var(--ink-soft);
      font-size: 12.5px;
    }
    li { margin-bottom: 3px; }
    .footer {
      margin-top: 8px;
      padding: 16px 28px 22px;
      border-top: 1px solid var(--line);
      display: flex;
      flex-wrap: wrap;
      gap: 10px 18px;
      align-items: center;
      justify-content: space-between;
      background: #fbfcfa;
    }
    .footer-copy {
      margin: 0;
      font-size: 11px;
      color: var(--mute);
      max-width: 48ch;
    }
    .footer-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      border-radius: 999px;
      background: var(--accent);
      color: #042f2e !important;
      font-size: 12px;
      font-weight: 700;
      text-decoration: none !important;
      box-shadow: 0 6px 16px rgba(15, 118, 110, 0.25);
    }
    .pulse {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #5eead4;
      box-shadow: 0 0 0 0 rgba(94, 234, 212, 0.7);
      animation: pulse 1.8s ease-out infinite;
    }
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(94, 234, 212, 0.55); }
      70% { box-shadow: 0 0 0 8px rgba(94, 234, 212, 0); }
      100% { box-shadow: 0 0 0 0 rgba(94, 234, 212, 0); }
    }
    @media print {
      body { background: #fff; }
      .sheet { margin: 0; padding: 0; max-width: none; }
      .card { box-shadow: none; border: none; border-radius: 0; }
      .footer-cta { box-shadow: none; }
      .pulse { animation: none; }
    }
  </style>
</head>
<body>
  <div class="sheet">
    <article class="card">
      <header class="hero">
        {% if cv.basics.image %}
        <img class="avatar" src="{{ cv.basics.image }}" alt="{{ cv.basics.name }} avatar" width="112" height="112" />
        {% else %}
        <div class="avatar avatar-fallback" aria-hidden="true">{{ nameInitial }}</div>
        {% endif %}
        <div class="identity">
          <h1>{{ cv.basics.name }}</h1>
          {% if cv.basics.label %}<div class="label">{{ cv.basics.label }}</div>{% endif %}
          <div class="handle-row">
            {% if github %}
            <a class="chip" href="https://github.com/{{ github }}" rel="noopener noreferrer">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
              @{{ github }}
            </a>
            {% endif %}
            {% if meta.liveProfileUrl %}
            <a class="chip live" href="{{ meta.liveProfileUrl }}" rel="noopener noreferrer">
              <span class="pulse" aria-hidden="true"></span>
              Verified on Gitwork
            </a>
            {% endif %}
          </div>
          <div class="meta">
            {% if cv.basics.location %}{{ cv.basics.location }}{% endif %}
            {% if cv.basics.email %}{% if cv.basics.location %} · {% endif %}{{ cv.basics.email }}{% endif %}
            {% if cv.basics.url %}{% if cv.basics.location or cv.basics.email %} · {% endif %}<a href="{{ cv.basics.url }}">{{ cv.basics.url }}</a>{% endif %}
          </div>
        </div>
      </header>

      <div class="body">
        {% if cv.basics.summary %}
        <p class="summary">{{ cv.basics.summary }}</p>
        {% endif %}

        {% if cv.skills and cv.skills.length %}
        <section>
          <h2>Skills</h2>
          <div class="skills">
            {% for s in cv.skills %}
            <div class="skill">
              <strong>{{ s.name }}</strong>
              {% if s.keywords and s.keywords.length %}<span>{{ s.keywords | join(", ") }}</span>{% endif %}
            </div>
            {% endfor %}
          </div>
        </section>
        {% endif %}

        {% if cv.repos and cv.repos.length %}
        <section>
          <h2>Repositories</h2>
          {% for r in cv.repos %}
          <div class="item">
            <div class="item-title">
              {% if r.url %}<a href="{{ r.url }}" rel="noopener noreferrer">{{ r.name }}</a>{% else %}{{ r.name }}{% endif %}
            </div>
            {% if r.language or r.stars != null %}<div class="item-sub">{% if r.language %}{{ r.language }}{% endif %}{% if r.language and r.stars != null %} · {% endif %}{% if r.stars != null %}{{ r.stars }} stars{% endif %}</div>{% endif %}
            {% if r.summary %}<p>{{ r.summary }}</p>{% endif %}
          </div>
          {% endfor %}
        </section>
        {% endif %}

        {% if cv.oss and cv.oss.length %}
        <section>
          <h2>Contributions</h2>
          {% for o in cv.oss %}
          <div class="item">
            <div class="item-title">{{ o.repo }}</div>
            {% if o.role %}<div class="item-sub">{{ o.role }}</div>{% endif %}
            {% if o.impact %}<p>{{ o.impact }}</p>{% endif %}
          </div>
          {% endfor %}
        </section>
        {% endif %}
      </div>

      <footer class="footer">
        <p class="footer-copy">
          Open Source CV generated on
          <a href="{{ meta.gitworkHomeUrl }}" rel="noopener noreferrer">Gitwork</a>
          {% if meta.generatedAt %} · {{ meta.generatedAt }}{% endif %}.
          Built from public GitHub evidence. View the live scout profile for the latest card and activity.
        </p>
        {% if meta.liveProfileUrl %}
        <a class="footer-cta" href="{{ meta.liveProfileUrl }}" rel="noopener noreferrer">
          <span class="pulse" aria-hidden="true"></span>
          View scout profile
        </a>
        {% endif %}
      </footer>
    </article>
  </div>
</body>
</html>
